{
  "name": "politost-smartbook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/copy-pyodide.mjs && node scripts/generate-headers.mjs",
    "build": "tsc -b && vite build",
    "postinstall": "node scripts/install-workspace-deps.mjs && node scripts/copy-pyodide.mjs",
    "prepare:e2e": "playwright install chromium",
    "lint": "eslint .",
    "preview": "vite preview",
    "validate:chapter": "tsx scripts/validate-chapter.ts",
    "pack:ptsb": "tsx scripts/pack-ptsb.ts",
    "test:security": "tsx --test src/lib/sanitizeHtml.test.ts",
    "test:content": "npm run test --prefix packages/content-core && tsx --test src/lib/safeMathExpr.test.ts",
    "test:print:unit": "tsx --test src/print/dedupePages.test.ts",
    "test:print": "npm run prepare:e2e && playwright test e2e/print.spec.ts",
    "test:e2e": "npm run prepare:e2e && playwright test",
    "test:e2e:ui": "npm run prepare:e2e && playwright test --ui"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@politost/content-core": "file:packages/content-core",
    "pagedjs": "file:packages/pagedjs-politost",
    "@tanstack/react-query": "^5.101.0",
    "dompurify": "^3.4.11",
    "fflate": "^0.8.3",
    "katex": "^0.17.0",
    "plotly.js": "^3.6.0",
    "pyodide": "^314.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^4.0.0",
    "react-router-dom": "^7.18.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  },
  "allowScripts": {
    "es5-ext@0.10.64": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
