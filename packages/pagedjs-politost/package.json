{
  "name": "pagedjs",
  "version": "0.4.3-politost.0",
  "description": "Chunks up a document into paged media flows and applies print styles (Politost: runtime-only vendored copy; dead @babel/polyfill removed)",
  "author": "Fred Chasen",
  "license": "MIT",
  "homepage": "https://pagedmedia.org",
  "main": "src/index.js",
  "browser": "dist/paged.js",
  "type": "module",
  "exports": {
    "import": "./src/index.js",
    "require": "./lib/index.cjs",
    "browser": "./dist/paged.js",
    "polyfill": "./dist/paged.polyfill.js",
    "default": "./src/index.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.21.0",
    "clear-cut": "^2.0.2",
    "css-tree": "^1.1.3",
    "event-emitter": "^0.3.5"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.coko.foundation/pagedjs/pagedjs.git"
  },
  "files": [
    "dist",
    "lib",
    "src"
  ]
}
